# ── 应用配置 ───────────────────────────────────────────────
# 对外暴露端口（默认 80）
APP_PORT=80

# ── 安全配置（生产环境务必修改！） ──────────────────────────
# JWT 密钥（建议使用 32 位以上随机字符串）
JWT_SECRET=please_change_this_to_a_strong_random_secret

# Token 有效期
JWT_EXPIRES_IN=7d

# bcrypt 加密轮数（数值越大越安全，但越慢）
BCRYPT_ROUNDS=10

# 允许跨域的前端地址
CLIENT_URL=http://localhost
